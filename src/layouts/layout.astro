---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Garden' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Dashboard' },
  { href: '/plants', label: 'Plants' },
  { href: '/calendar', label: 'Calendar' },
  { href: '/transplant', label: 'Transplant' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-10 bg-parchment/90 backdrop-blur-md">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-display text-2xl font-semibold text-ink tracking-tight italic">Garden</a>
        <div class="flex items-center gap-6">
          <div id="env-toggle" class="flex gap-3">
            <button
              data-env="outdoor"
              class="env-btn pb-0.5 font-medium transition-all border-b-2"
            >
              Outdoor
            </button>
            <button
              data-env="indoor"
              class="env-btn pb-0.5 font-medium transition-all border-b-2"
            >
              Indoor
            </button>
          </div>
          <span class="w-px h-4 bg-rule"></span>
          <nav class="flex gap-1">
            {nav.map(({ href, label }) => {
              const active = href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(href);
              return (
                <a
                  href={href}
                  class:list={[
                    'px-3.5 py-2 rounded-md font-medium transition-colors',
                    active
                      ? 'bg-terra/10 text-terra'
                      : 'text-ink-soft hover:text-ink',
                  ]}
                >
                  {label}
                </a>
              );
            })}
          </nav>
        </div>
      </div>
      <div class="max-w-5xl mx-auto px-6">
        <div class="h-px bg-gradient-to-r from-transparent via-rule to-transparent"></div>
      </div>
    </header>
    <main class="max-w-5xl mx-auto px-6 py-8">
      <slot />
    </main>
    <script>
      function initEnvToggle() {
        const env = localStorage.getItem('garden-env') || 'outdoor';
        applyEnv(env);

        document.querySelectorAll<HTMLButtonElement>('.env-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const selected = btn.dataset.env!;
            localStorage.setItem('garden-env', selected);
            applyEnv(selected);
          });
        });
      }

      function applyEnv(env: string) {
        document.querySelectorAll<HTMLButtonElement>('.env-btn').forEach((btn) => {
          const active = btn.dataset.env === env;
          btn.classList.toggle('border-terra', active);
          btn.classList.toggle('text-terra', active);
          btn.classList.toggle('border-transparent', !active);
          btn.classList.toggle('text-ink-faint', !active);
        });

        document.querySelectorAll<HTMLElement>('[data-indoor]').forEach((el) => {
          const isIndoor = el.dataset.indoor === 'true';
          const show = env === 'indoor' ? isIndoor : !isIndoor;
          el.style.display = show ? '' : 'none';
        });

        document.querySelectorAll<HTMLElement>('[data-env-summary]').forEach((el) => {
          const outdoor = el.dataset.envSummaryOutdoor || '';
          const indoor = el.dataset.envSummaryIndoor || '';
          el.textContent = env === 'indoor' ? indoor : outdoor;
        });

        document.body.dataset.env = env;
      }

      initEnvToggle();
      document.addEventListener('astro:after-swap', initEnvToggle);
    </script>
  </body>
</html>
