---
import Layout from '../layouts/layout.astro';
import { getCollection } from 'astro:content';
import { getCurrentMonth, getTasksForMonth, getPlantsNeedingAttention, MONTH_NAMES, CATEGORY_LABELS, CATEGORY_COLORS, SEASONAL_CONTEXT } from '../lib/utils';
import AttentionCard from '../components/AttentionCard.astro';

const allPlants = await getCollection('plants');
const currentMonth = getCurrentMonth();
const nextMonth = currentMonth === 12 ? 1 : currentMonth + 1;

const imageMap = new Map(allPlants.map(p => [p.id, p.data.image]));

const outdoorPlants = allPlants.filter((p) => !p.data.indoor);
const indoorPlants = allPlants.filter((p) => p.data.indoor);

const outdoorTasks = getTasksForMonth(outdoorPlants, currentMonth);
const indoorTasks = getTasksForMonth(indoorPlants, currentMonth);
const outdoorNextTasks = getTasksForMonth(outdoorPlants, nextMonth);
const indoorNextTasks = getTasksForMonth(indoorPlants, nextMonth);

function groupByCategory(tasks: ReturnType<typeof getTasksForMonth>) {
  return tasks.reduce<Record<string, typeof tasks>>((acc, task) => {
    if (!acc[task.category]) acc[task.category] = [];
    acc[task.category].push(task);
    return acc;
  }, {});
}

const outdoorByCategory = groupByCategory(outdoorTasks);
const indoorByCategory = groupByCategory(indoorTasks);

const outdoorAttention = getPlantsNeedingAttention(outdoorPlants);
const indoorAttention = getPlantsNeedingAttention(indoorPlants);

const seasonalContext = SEASONAL_CONTEXT[currentMonth];
const isAutumn = currentMonth >= 4 && currentMonth <= 5;

const outdoorPhotosNeeded = outdoorPlants.filter(p => p.data.photoNeeded);
const indoorPhotosNeeded = indoorPlants.filter(p => p.data.photoNeeded);

type TaskGroup = {
  indoor: boolean;
  tasks: ReturnType<typeof getTasksForMonth>;
  byCategory: Record<string, ReturnType<typeof getTasksForMonth>>;
  nextTasks: ReturnType<typeof getTasksForMonth>;
  plantCount: number;
  attention: typeof outdoorAttention;
  photosNeeded: typeof outdoorPhotosNeeded;
};
const groups: TaskGroup[] = [
  { indoor: false, tasks: outdoorTasks, byCategory: outdoorByCategory, nextTasks: outdoorNextTasks, plantCount: outdoorPlants.length, attention: outdoorAttention, photosNeeded: outdoorPhotosNeeded },
  { indoor: true, tasks: indoorTasks, byCategory: indoorByCategory, nextTasks: indoorNextTasks, plantCount: indoorPlants.length, attention: indoorAttention, photosNeeded: indoorPhotosNeeded },
];
---

<Layout title="Garden Dashboard">
  {groups.map(({ indoor, tasks, byCategory, nextTasks, plantCount, attention, photosNeeded }) => (
    <div data-indoor={String(indoor)} class="animate-in space-y-10">
      <div>
        <h1 class="text-6xl font-semibold text-ink tracking-tight">
          {MONTH_NAMES[currentMonth - 1]}
        </h1>
        <p class="text-ink-soft mt-3 text-lg">
          {tasks.length} task{tasks.length !== 1 ? 's' : ''} across {plantCount} plant{plantCount !== 1 ? 's' : ''}
          {attention.attention.length > 0 && (
            <span> · {attention.attention.length} need{attention.attention.length === 1 ? 's' : ''} attention</span>
          )}
        </p>
      </div>

      {!indoor && (
        <section class="bg-paper rounded-xl border border-rule-light border-l-4 border-l-olive p-5 space-y-5">
          <div class="flex items-baseline justify-between">
            <h2 class="font-display text-lg font-semibold text-ink">Right now — autumn work</h2>
            <a href="/transplant" class="text-sm text-terra hover:text-terra/80 font-medium transition-colors">Transplant plan &rarr;</a>
          </div>

          <div>
            <p class="text-sm font-semibold text-ink mb-2">Mulching (before the cold sets in)</p>
            <ul class="space-y-1.5 text-ink-soft text-sm">
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>New perennial bed (transplants) — 3-5cm sugar cane or pea straw, keep 5cm off stems</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Feijoa, Banksia, Cinnamon Wattle — mulch around the base</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Strawberry — straw mulch specifically (keeps fruit off soil)</span></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-ink mb-2">Cutting back / tidying</p>
            <ul class="space-y-1.5 text-ink-soft text-sm">
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Kangaroo Paw (front + back) — cut spent flower stalks to base, pull dead leaves from centre of clumps</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Achillea — cut back any remaining spent flower stems</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Native daisies — tidy spent flowers</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Birds nest fern — clear dead material from centre of rosette, remove worst brown fronds</span></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-ink mb-2">Weeding</p>
            <ul class="space-y-1.5 text-ink-soft text-sm">
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Nature strip — hand-weed the small weeds through the grass</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Lavender base — clear the weedy grass around it</span></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-ink mb-2">Transplant post-care (April 16 →)</p>
            <ul class="space-y-1.5 text-ink-soft text-sm">
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Watch transplants for wilting over 1-2 weeks. Water gently if they droop.</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>No fertiliser on transplants for 2-3 weeks</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Follow-up Epsom salts on citrus in 2-3 weeks if yellowing persists</span></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-ink mb-2">When flowering finishes</p>
            <ul class="space-y-1.5 text-ink-soft text-sm">
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Lavender — hard prune into lowest green growth (not bare wood). Critical intervention this year.</span></li>
              <li class="flex gap-3"><span class="text-olive shrink-0">·</span><span>Mexican Sage — cut back by half to two-thirds (usually May-June)</span></li>
            </ul>
          </div>
        </section>
      )}

      {photosNeeded.length > 0 && (
        <section class="bg-terra-soft/50 rounded-xl border border-terra/15 p-5">
          <h2 class="font-display text-lg font-semibold text-terra mb-3">Photos needed</h2>
          <ul class="space-y-2.5">
            {photosNeeded.map((plant) => (
              <li class="flex items-start gap-3">
                <a href={`/plants/${plant.id}`} class="text-terra hover:text-terra/80 font-medium transition-colors shrink-0 whitespace-nowrap">
                  {plant.data.name}
                </a>
                <span class="text-sm text-ink-soft">{plant.data.photoNeeded}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {seasonalContext && (
        <div class="bg-olive-soft/60 border border-olive/10 rounded-xl p-5">
          <p class="font-display text-lg font-semibold text-olive">{seasonalContext.headline}</p>
          <p class="text-ink-soft mt-1">{seasonalContext.description}</p>
        </div>
      )}

      {attention.attention.length > 0 && (
        <section>
          <h2 class="text-2xl font-semibold text-ink mb-4 flex items-baseline gap-3">
            Needs attention
            <span class="text-ink-faint text-sm font-normal">
              {attention.attention.length} flagged
            </span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {attention.attention.map((plant) => (
              <AttentionCard plant={plant} />
            ))}
          </div>
        </section>
      )}

      {attention.unassessed.length > 0 && (
        <div class="bg-paper/60 rounded-xl border border-rule-light p-5">
          <p class="text-sm font-medium text-ink-soft mb-3">Needs assessment</p>
          <div class="flex flex-wrap gap-2">
            {attention.unassessed.map((plant) => (
              <a
                href={`/plants/${plant.id}`}
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-stone-100 text-sm text-stone-600 hover:bg-stone-200 transition-colors"
              >
                {plant.data.name}
              </a>
            ))}
          </div>
        </div>
      )}

      {indoor && isAutumn && (
        <section class="bg-terra-soft/40 rounded-xl border border-terra/15 p-6">
          <h2 class="text-xl font-semibold text-ink mb-1">
            Indoor autumn care
          </h2>
          <p class="font-display italic text-ink-soft mb-4 text-sm">
            A few things worth doing across the whole indoor collection this month.
          </p>
          <ul class="space-y-1.5 text-ink text-sm">
            <li class="flex gap-3"><span class="text-terra">·</span>Water less often — check soil 2cm down before watering. Cool rooms dry slowly.</li>
            <li class="flex gap-3"><span class="text-terra">·</span>Boost humidity for ferns and Grey Star — pebble trays or group plants.</li>
            <li class="flex gap-3"><span class="text-terra">·</span>Yellow sticky traps for fungus gnats — autumn is peak.</li>
            <li class="flex gap-3"><span class="text-terra">·</span>Wipe dust off broadleaves so they can photosynthesise in low light.</li>
            <li class="flex gap-3"><span class="text-terra">·</span>Shift plants closer to the brightest windows. Daylight drops fast from here.</li>
            <li class="flex gap-3"><span class="text-terra">·</span>Hold off feeding until spring (September) — no growth, no feed.</li>
          </ul>
        </section>
      )}

      {tasks.length === 0 ? (
        <div class="bg-paper rounded-xl p-10 text-center border border-rule-light">
          <p class="text-ink-faint italic font-display text-lg">Nothing to do this month. Nice.</p>
        </div>
      ) : (
        <div class="space-y-5">
          {Object.entries(byCategory).map(([category, catTasks]) => (
            <div class="bg-paper rounded-xl border border-rule-light overflow-hidden">
              <div class="px-5 py-3 border-b border-rule-light/60 flex items-center gap-3">
                <span class:list={['inline-block px-2.5 py-1 rounded-md text-xs font-semibold tracking-wide uppercase', CATEGORY_COLORS[category]]}>
                  {CATEGORY_LABELS[category]}
                </span>
                <span class="text-ink-faint text-sm">{catTasks.length} task{catTasks.length !== 1 ? 's' : ''}</span>
              </div>
              <ul class="divide-y divide-rule-light/60">
                {catTasks.map((task) => (
                  <li class="px-5 py-5 flex items-center gap-4">
                    <a
                      href={`/plants/${task.plantId}`}
                      class="flex items-center gap-3 shrink-0 text-terra hover:text-terra/80 font-medium transition-colors"
                    >
                      {imageMap.get(task.plantId) && (
                        <img
                          src={imageMap.get(task.plantId)}
                          alt=""
                          class="w-12 h-12 rounded-full object-cover border border-rule-light"
                          loading="lazy"
                        />
                      )}
                      <span class="whitespace-nowrap">{task.plantName}</span>
                    </a>
                    <span class="text-ink-soft">{task.task}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}

      {nextTasks.length > 0 && (
        <div>
          <h2 class="text-3xl font-semibold text-ink mb-4">
            Coming up in {MONTH_NAMES[nextMonth - 1]}
          </h2>
          <div class="bg-paper/60 rounded-xl border border-rule-light p-5">
            <ul class="space-y-3">
              {nextTasks.map((task) => (
                <li class="flex items-center gap-4">
                  <a
                    href={`/plants/${task.plantId}`}
                    class="flex items-center gap-2.5 shrink-0 text-terra hover:text-terra/80 font-medium transition-colors"
                  >
                    {imageMap.get(task.plantId) && (
                      <img
                        src={imageMap.get(task.plantId)}
                        alt=""
                        class="w-10 h-10 rounded-full object-cover border border-rule-light"
                        loading="lazy"
                      />
                    )}
                    <span class="whitespace-nowrap">{task.plantName}</span>
                  </a>
                  <span class:list={['inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold tracking-wide uppercase shrink-0', CATEGORY_COLORS[task.category]]}>
                    {CATEGORY_LABELS[task.category]}
                  </span>
                  <span class="text-ink-soft">{task.task}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </div>
  ))}
</Layout>
