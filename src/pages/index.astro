---
import Layout from '../layouts/layout.astro';
import { getCollection } from 'astro:content';
import { getCurrentMonth, getTasksForMonth, MONTH_NAMES, CATEGORY_LABELS, CATEGORY_COLORS } from '../lib/utils';

const allPlants = await getCollection('plants');
const currentMonth = getCurrentMonth();
const nextMonth = currentMonth === 12 ? 1 : currentMonth + 1;

const imageMap = new Map(allPlants.map(p => [p.id, p.data.image]));

const outdoorPlants = allPlants.filter((p) => !p.data.indoor);
const indoorPlants = allPlants.filter((p) => p.data.indoor);

const outdoorTasks = getTasksForMonth(outdoorPlants, currentMonth);
const indoorTasks = getTasksForMonth(indoorPlants, currentMonth);
const outdoorNextTasks = getTasksForMonth(outdoorPlants, nextMonth);
const indoorNextTasks = getTasksForMonth(indoorPlants, nextMonth);

function groupByCategory(tasks: ReturnType<typeof getTasksForMonth>) {
  return tasks.reduce<Record<string, typeof tasks>>((acc, task) => {
    if (!acc[task.category]) acc[task.category] = [];
    acc[task.category].push(task);
    return acc;
  }, {});
}

const outdoorByCategory = groupByCategory(outdoorTasks);
const indoorByCategory = groupByCategory(indoorTasks);

type TaskGroup = { indoor: boolean; tasks: ReturnType<typeof getTasksForMonth>; byCategory: Record<string, ReturnType<typeof getTasksForMonth>>; nextTasks: ReturnType<typeof getTasksForMonth>; plantCount: number };
const groups: TaskGroup[] = [
  { indoor: false, tasks: outdoorTasks, byCategory: outdoorByCategory, nextTasks: outdoorNextTasks, plantCount: outdoorPlants.length },
  { indoor: true, tasks: indoorTasks, byCategory: indoorByCategory, nextTasks: indoorNextTasks, plantCount: indoorPlants.length },
];
---

<Layout title="Garden Dashboard">
  {groups.map(({ indoor, tasks, byCategory, nextTasks, plantCount }) => (
    <div data-indoor={String(indoor)} class="animate-in space-y-10">
      <div>
        <h1 class="text-6xl font-semibold text-ink tracking-tight">
          {MONTH_NAMES[currentMonth - 1]}
        </h1>
        <p class="text-ink-soft mt-3 text-lg">
          {tasks.length} task{tasks.length !== 1 ? 's' : ''} across {plantCount} plant{plantCount !== 1 ? 's' : ''}
        </p>
      </div>

      {tasks.length === 0 ? (
        <div class="bg-paper rounded-xl p-10 text-center border border-rule-light">
          <p class="text-ink-faint italic font-display text-lg">Nothing to do this month. Nice.</p>
        </div>
      ) : (
        <div class="space-y-5">
          {Object.entries(byCategory).map(([category, catTasks]) => (
            <div class="bg-paper rounded-xl border border-rule-light overflow-hidden">
              <div class="px-5 py-3 border-b border-rule-light/60 flex items-center gap-3">
                <span class:list={['inline-block px-2.5 py-1 rounded-md text-xs font-semibold tracking-wide uppercase', CATEGORY_COLORS[category]]}>
                  {CATEGORY_LABELS[category]}
                </span>
                <span class="text-ink-faint text-sm">{catTasks.length} task{catTasks.length !== 1 ? 's' : ''}</span>
              </div>
              <ul class="divide-y divide-rule-light/60">
                {catTasks.map((task) => (
                  <li class="px-5 py-5 flex items-center gap-4">
                    <a
                      href={`/plants/${task.plantId}`}
                      class="flex items-center gap-3 shrink-0 text-terra hover:text-terra/80 font-medium transition-colors"
                    >
                      {imageMap.get(task.plantId) && (
                        <img
                          src={imageMap.get(task.plantId)}
                          alt=""
                          class="w-12 h-12 rounded-full object-cover border border-rule-light"
                          loading="lazy"
                        />
                      )}
                      <span class="whitespace-nowrap">{task.plantName}</span>
                    </a>
                    <span class="text-ink-soft">{task.task}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}

      {nextTasks.length > 0 && (
        <div>
          <h2 class="text-3xl font-semibold text-ink mb-4">
            Coming up in {MONTH_NAMES[nextMonth - 1]}
          </h2>
          <div class="bg-paper/60 rounded-xl border border-rule-light p-5">
            <ul class="space-y-3">
              {nextTasks.map((task) => (
                <li class="flex items-center gap-4">
                  <a
                    href={`/plants/${task.plantId}`}
                    class="flex items-center gap-2.5 shrink-0 text-terra hover:text-terra/80 font-medium transition-colors"
                  >
                    {imageMap.get(task.plantId) && (
                      <img
                        src={imageMap.get(task.plantId)}
                        alt=""
                        class="w-10 h-10 rounded-full object-cover border border-rule-light"
                        loading="lazy"
                      />
                    )}
                    <span class="whitespace-nowrap">{task.plantName}</span>
                  </a>
                  <span class:list={['inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold tracking-wide uppercase shrink-0', CATEGORY_COLORS[task.category]]}>
                    {CATEGORY_LABELS[task.category]}
                  </span>
                  <span class="text-ink-soft">{task.task}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </div>
  ))}
</Layout>
